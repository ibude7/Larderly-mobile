# Larderly (mobile) environment
#
# NOTE: With @react-native-firebase, the core Firebase config (apiKey,
# projectId, appId, etc.) is NOT read from here. It comes from the native
# config files you download from the Firebase console:
#   - iOS:     GoogleService-Info.plist   (place in mobile/ root)
#   - Android: google-services.json       (place in mobile/ root)
# See SETUP.md for step-by-step instructions.

# ── Google Sign-In ──────────────────────────────────────────────────────────
# The REVERSED_CLIENT_ID from GoogleService-Info.plist (starts with
# "com.googleusercontent.apps."). Required for native Google Sign-In on iOS.
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=

# Web client ID (type 3 / "Web application" OAuth client) from the Google Cloud
# console. Used by @react-native-google-signin to obtain a Firebase idToken.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# ── Dev toggles ─────────────────────────────────────────────────────────────
# Set to "true" to skip the auth gate while developing UI locally.
EXPO_PUBLIC_BYPASS_AUTH=false
