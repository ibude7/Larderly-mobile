rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function household(householdId) {
      return get(/databases/$(database)/documents/households/$(householdId));
    }

    function isHouseholdMember(householdId) {
      return isSignedIn()
        && household(householdId).data.keys().hasAll(['members'])
        && request.auth.uid in household(householdId).data.members;
    }

    function isHouseholdOwner(householdId) {
      return isSignedIn()
        && household(householdId).data.ownerId == request.auth.uid;
    }

    function householdRole(householdId) {
      let data = household(householdId).data;
      return data.ownerId == request.auth.uid
        ? 'admin'
        : data.memberRoles.get(request.auth.uid, 'editor');
    }

    function canEditHousehold(householdId) {
      return isHouseholdMember(householdId) && householdRole(householdId) != 'viewer';
    }

    function isJoiningHousehold() {
      return isSignedIn()
        && !(request.auth.uid in resource.data.members)
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members.size() == resource.data.members.size() + 1;
    }

    // ── User profile & private subcollections ───────────────────────────────
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /loginEvents/{eventId} {
        allow read, create: if isOwner(userId);
        allow update, delete: if false;
      }

      match /favorites/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /recipeRatings/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /meal_plans/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /notifications/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /fcmTokens/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /nutrition/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /gamification/{docId} {
        allow read, write: if isOwner(userId);
      }

      // Legacy paths — read/write for migration cleanup only
      match /storage_locations/{locationId} {
        allow read, write: if isOwner(userId);
      }

      match /pantry/{itemId} {
        allow read, write: if isOwner(userId);
      }

      match /pantry_items/{itemId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ── Households (shared pantry, lists, activity) ─────────────────────────
    match /households/{householdId} {
      allow read: if isHouseholdMember(householdId);
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.members;
      allow update: if isHouseholdOwner(householdId)
        || isJoiningHousehold()
        || (isHouseholdMember(householdId) && canEditHousehold(householdId));
      allow delete: if isHouseholdOwner(householdId);

      match /inventory/{itemId} {
        allow read: if isHouseholdMember(householdId);
        allow create, update, delete: if canEditHousehold(householdId);
      }

      match /storageLocations/{locationId} {
        allow read: if isHouseholdMember(householdId);
        allow create, update, delete: if canEditHousehold(householdId);
      }

      match /shoppingLists/{listId} {
        allow read: if isHouseholdMember(householdId);
        allow create, update, delete: if canEditHousehold(householdId);

        match /items/{itemId} {
          allow read: if isHouseholdMember(householdId);
          allow create, update, delete: if canEditHousehold(householdId);
        }
      }

      match /activity/{eventId} {
        allow read: if isHouseholdMember(householdId);
        allow create: if canEditHousehold(householdId);
        allow update, delete: if false;
      }

      match /reminders/{reminderId} {
        allow read: if isHouseholdMember(householdId);
        allow create, update, delete: if canEditHousehold(householdId);
      }

      match /recipeViews/{recipeId} {
        allow read: if isHouseholdMember(householdId);
        allow create, update: if isHouseholdMember(householdId);
        allow delete: if canEditHousehold(householdId);
      }
    }

    // ── Invite codes ────────────────────────────────────────────────────────
    match /inviteCodes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.ownerId == request.auth.uid;
    }

    // ── Shared product barcode cache ────────────────────────────────────────
    match /products/{barcode} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    // ── User-created recipes catalog ────────────────────────────────────────
    match /recipes/{recipeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.createdBy == request.auth.uid;
    }
  }
}
