rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function household(householdId) {
      return get(/databases/$(database)/documents/households/$(householdId));
    }

    function isHouseholdMember(householdId) {
      return isSignedIn()
        && household(householdId).data.keys().hasAll(['members'])
        && request.auth.uid in household(householdId).data.members;
    }

    function isHouseholdOwner(householdId) {
      return isSignedIn()
        && household(householdId).data.ownerId == request.auth.uid;
    }

    function householdRole(householdId) {
      let data = household(householdId).data;
      return data.ownerId == request.auth.uid
        ? 'admin'
        : data.memberRoles.get(request.auth.uid, 'editor');
    }

    function canEditHousehold(householdId) {
      return isHouseholdMember(householdId) && householdRole(householdId) != 'viewer';
    }

    function isAdminRemovingHouseholdMember(userId) {
      return resource.data.householdId is string
        && isAdminRemovingHouseholdMemberFrom(userId, resource.data.householdId);
    }

    function isAdminRemovingHouseholdMemberFrom(userId, householdId) {
      let householdPath = /databases/$(database)/documents/households/$(householdId);
      return isSignedIn()
        && householdId != ''
        && exists(householdPath)
        && existsAfter(householdPath)
        && get(householdPath).data.ownerId != userId
        && userId in get(householdPath).data.members
        && !(userId in getAfter(householdPath).data.members)
        && (
          get(householdPath).data.ownerId == request.auth.uid
          || get(householdPath).data.memberRoles.get(request.auth.uid, 'editor') == 'admin'
        )
        && request.resource.data.householdId == ''
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['householdId', 'updated_at']);
    }

    function validShortString(value, maxLen) {
      return value is string && value.size() <= maxLen;
    }

    function validProductCacheWrite() {
      return request.resource.data.keys().hasAll(['name', 'brand', 'category'])
        && validShortString(request.resource.data.name, 200)
        && validShortString(request.resource.data.brand, 200)
        && validShortString(request.resource.data.category, 200);
    }

    function validInventoryWrite() {
      return request.resource.data.keys().hasAll(['name'])
        && validShortString(request.resource.data.name, 100);
    }

    function inviteCounterPath(ownerId, rateLimitKey) {
      return /databases/$(database)/documents/users/$(ownerId)/inviteCodeCounters/$(rateLimitKey);
    }

    function validInviteCounterAfterWrite(ownerId) {
      return request.resource.data.rateLimitKey is string
        && validInviteCounterIncrement(ownerId, request.resource.data.rateLimitKey);
    }

    function validInviteCounterIncrement(ownerId, rateLimitKey) {
      let path = inviteCounterPath(ownerId, rateLimitKey);
      return existsAfter(path)
        && getAfter(path).data.ownerId == ownerId
        && getAfter(path).data.count is int
        && getAfter(path).data.count >= 1
        && getAfter(path).data.count <= 10
        && getAfter(path).data.windowStart is timestamp
        && getAfter(path).data.updatedAt is timestamp
        && (
          (!exists(path) && getAfter(path).data.count == 1)
          || (exists(path)
            && get(path).data.windowStart == getAfter(path).data.windowStart
            && getAfter(path).data.count == get(path).data.count + 1)
        );
    }

    function isJoiningHousehold() {
      return isSignedIn()
        && !(request.auth.uid in resource.data.members)
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members.size() == resource.data.members.size() + 1;
    }

    // ── User profile & private subcollections ───────────────────────────────
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      allow update: if isAdminRemovingHouseholdMember(userId);

      match /loginEvents/{eventId} {
        allow read, create, delete: if isOwner(userId);
        allow update: if false;
      }

      match /favorites/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /recipeRatings/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /meal_plans/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /notifications/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /fcmTokens/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /nutrition/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /settings/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /gamification/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /inviteCodeCounters/{counterId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && validInviteCounterIncrement(request.auth.uid, counterId);
        allow delete: if false;
      }

      // Legacy paths — read/write for migration cleanup only
      match /storage_locations/{locationId} {
        allow read, write: if isOwner(userId);
      }

      match /pantry/{itemId} {
        allow read, write: if isOwner(userId);
      }

      match /pantry_items/{itemId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ── Households (shared pantry, lists, activity) ─────────────────────────
    match /households/{householdId} {
      allow read: if isHouseholdMember(householdId);
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.members;
      allow update: if (
          isHouseholdOwner(householdId)
          || isJoiningHousehold()
          || (isHouseholdMember(householdId) && canEditHousehold(householdId))
        )
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.ownerId in request.resource.data.members;
      allow delete: if isHouseholdOwner(householdId);

      match /inventory/{itemId} {
        allow read: if isHouseholdMember(householdId);
        allow create, update: if canEditHousehold(householdId) && validInventoryWrite();
        allow delete: if canEditHousehold(householdId);
      }

      match /storageLocations/{locationId} {
        allow read: if isHouseholdMember(householdId);
        allow create, update, delete: if canEditHousehold(householdId);
      }

      match /shoppingLists/{listId} {
        allow read: if isHouseholdMember(householdId);
        allow create, update, delete: if canEditHousehold(householdId);

        match /items/{itemId} {
          allow read: if isHouseholdMember(householdId);
          allow create, update, delete: if canEditHousehold(householdId);
        }
      }

      match /activity/{eventId} {
        allow read: if isHouseholdMember(householdId);
        allow create: if canEditHousehold(householdId);
        allow update, delete: if false;
      }

      match /reminders/{reminderId} {
        allow read: if isHouseholdMember(householdId);
        allow create, update, delete: if canEditHousehold(householdId);
      }

      match /recipeViews/{recipeId} {
        allow read: if isHouseholdMember(householdId);
        allow create, update: if isHouseholdMember(householdId);
        allow delete: if canEditHousehold(householdId);
      }
    }

    // ── Invite codes ────────────────────────────────────────────────────────
    match /inviteCodes/{code} {
      allow read: if isSignedIn() && resource.data.expiresAt > request.time;
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.expiresAt is timestamp
        && validInviteCounterAfterWrite(request.auth.uid);
      allow update, delete: if isSignedIn()
        && resource.data.ownerId == request.auth.uid;
    }

    // ── Shared product barcode cache ────────────────────────────────────────
    match /products/{barcode} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && validProductCacheWrite();
      allow delete: if false;
    }

    // ── User-created recipes catalog ────────────────────────────────────────
    match /recipes/{recipeId} {
      allow read: if isSignedIn() && (
        resource.data.isPublic == true
        || resource.data.createdBy == request.auth.uid
        || (resource.data.householdId is string && isHouseholdMember(resource.data.householdId))
      );
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.createdBy == request.auth.uid;
    }
  }
}
