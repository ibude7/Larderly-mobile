# Server-side environment variables for Cloud Functions.
# These are NEVER bundled into the mobile app.
# Copy this file to .env and fill in the values.
# When deployed to Cloud Functions, set these via:
#   firebase functions:config:set  (v1 style)
#   or Google Cloud Secret Manager / process.env (v2 style)

# Google Cloud project that owns the Vertex AI quota.
# Must match the Firebase project (larderly1).
VERTEX_AI_PROJECT=larderly1

# Vertex AI region — must match the Firebase AI Logic region used in the app.
VERTEX_AI_LOCATION=us-central1

# Primary fast model (cheap, high-throughput).
GEMINI_MODEL_FLASH=gemini-2.5-flash

# Model used for product notes (stable, slightly smarter text).
GEMINI_MODEL_NOTE=gemini-2.5-flash

# Fallback model IDs if the primary ones are unavailable.
# Comma-separated, tried in order.
GEMINI_MODEL_FLASH_FALLBACKS=gemini-2.5-flash
GEMINI_MODEL_NOTE_FALLBACKS=gemini-2.5-flash
